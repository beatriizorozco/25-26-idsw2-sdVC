@startuml eliminarPerfil
skinparam linetype polyline

state in1 as "SOLICITUD_ELIMINACION_PERFIL_ABIERTA"
in1 -[#green]-> eliminarPerfil


state eliminarPerfil as "eliminarPerfil()" {

    state " " as MostrandoSolicitud
    state " " as ConfirmandoEliminacion

    [*] -[#green]-> MostrandoSolicitud
    note on link
    <b>Coordinador</b> tiene una solicitud de eliminación de perfil abierta
    <b>Coordinador</b> solicita eliminar el perfil
    end note

    MostrandoSolicitud -[#green]-> ConfirmandoEliminacion
    note on link
    <b>Sistema</b> presenta los datos de la solicitud:
    • Nombre del investigador
    • Correo electrónico
    • Fecha de solicitud
    • Motivo

    y presenta la confirmación de eliminación:
    • ¿Está seguro de eliminar este perfil?
    • Advertencia: esta acción no se puede deshacer.

    <b>Al confirmar:</b>
    • Se eliminará el perfil del investigador del sistema
    • Se volverá al listado de solicitudes actualizado

    y permite solicitar las siguientes acciones:
    • Confirmar eliminación
    • Cancelar
    end note

    ConfirmandoEliminacion -[#green]-> [*]
    note on link
    <b>Coordinador</b> solicita confirmar eliminación
    <b>Sistema</b> visualiza el listado de solicitudes actualizado
    end note

    ConfirmandoEliminacion -[#red]-> MostrandoSolicitud
    note on link
    <b>Coordinador</b> cancela eliminación
    <b>Sistema</b> visualiza la solicitud sin cambios
    end note
}

eliminarPerfil -[#green]-> SOLICITUDES_ELIMINACION_PERFIL_ABIERTAS
note on link
abrirSolicitudesEliminacionPerfil()
end note

eliminarPerfil -[#red]-> SOLICITUD_ELIMINACION_PERFIL_ABIERTA
note on link
Eliminación cancelada
end note

@enduml
