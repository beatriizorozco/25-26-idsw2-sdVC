@startuml abrirEntregable-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":ENTREGABLES_ABIERTOS" as EstadoEntrada
package abrirEntregable as "abrirEntregable()" {
    rectangle #629EF9 DetalleEntregableView
    rectangle #b5bd68 EntregableController
    rectangle #F2AC4E EntregableRepository
    rectangle #F2AC4E Entregable
}

rectangle #CDEBA5 ":ENTREGABLE_ABIERTO" as EstadoSalida
rectangle #CDEBA5 ":Collaboration EditarEntregable" as EditarEntregable
rectangle #CDEBA5 ":Collaboration EliminarEntregable" as EliminarEntregable
rectangle #CDEBA5 ":Collaboration AbrirEntregables" as AbrirEntregables

EstadoEntrada -r-> DetalleEntregableView: abrirEntregable()

DetalleEntregableView -d-> EntregableController: obtenerEntregable(id)
DetalleEntregableView --> EntregableController: prepararAccionesDisponibles(coordinador)
EntregableController --> EntregableRepository: obtenerActivoPorId(id)
EntregableRepository -- Entregable
DetalleEntregableView ..> EstadoSalida: continuarNavegacion()
DetalleEntregableView ..> EditarEntregable: editarEntregable()
DetalleEntregableView ..> EliminarEntregable: eliminarEntregable()
DetalleEntregableView ..> AbrirEntregables: abrirEntregables()

@enduml
