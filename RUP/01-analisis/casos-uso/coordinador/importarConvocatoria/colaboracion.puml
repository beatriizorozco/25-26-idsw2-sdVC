@startuml importarConvocatoria-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":CONVOCATORIA_ABIERTA" as EstadoEntrada
package importarConvocatoria as "importarConvocatoria()" {
    rectangle #629EF9 ImportarConvocatoriaView
    rectangle #b5bd68 ConvocatoriaController
    rectangle #F2AC4E ConvocatoriaRepository
    rectangle #F2AC4E Convocatoria
}

rectangle #CDEBA5 ":CONVOCATORIA_ABIERTA" as EstadoSalida


EstadoEntrada -r-> ImportarConvocatoriaView: importarConvocatoria()

ImportarConvocatoriaView -d-> ConvocatoriaController: importarConvocatoria(datos)
ImportarConvocatoriaView --> ConvocatoriaController: validarConvocatoriaExterna(datos)
ConvocatoriaController --> ConvocatoriaRepository: existeConvocatoria(datos)
ConvocatoriaController --> ConvocatoriaRepository: guardar(convocatoria)
ConvocatoriaRepository -- Convocatoria
ImportarConvocatoriaView ..> EstadoSalida: continuarNavegacion()


@enduml
