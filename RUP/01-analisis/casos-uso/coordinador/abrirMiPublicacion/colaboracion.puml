@startuml abrirMiPublicacion-coordinador-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":MIS_PUBLICACIONES_ABIERTAS" as EstadoEntrada
package abrirMiPublicacion as "abrirMiPublicacion()" {
    rectangle #629EF9 "abrirMiPublicacionView" as View
    rectangle #b5bd68 PublicacionController
    rectangle #b5bd68 PoliticaPublicacion
    rectangle #F2AC4E PublicacionRepository
    rectangle #F2AC4E Publicacion
    rectangle #F2AC4E RespuestaRepository
    rectangle #F2AC4E ArchivoPublicacionRepository
    rectangle #F2AC4E Respuesta
    rectangle #F2AC4E ArchivoPublicacion
}
rectangle #CDEBA5 ":MI_PUBLICACION_ABIERTA" as EstadoSalida

EstadoEntrada -r-> View: abrirMiPublicacion()
View -d-> PublicacionController: abrirMiPublicacion(solicitud, actor)
PublicacionController --> PublicacionRepository: obtenerActivaPorId(id)
PublicacionController --> PoliticaPublicacion: exigirAutoria(actor, publicacion)

PublicacionRepository -- Publicacion
PublicacionController --> RespuestaRepository: buscarPorPublicacion(id)
PublicacionController --> ArchivoPublicacionRepository: buscarPorPublicacion(id)
RespuestaRepository -- Respuesta
ArchivoPublicacionRepository -- ArchivoPublicacion
View ..> EstadoSalida: continuarNavegacion()

note right of PoliticaPublicacion
Responsabilidad unica:
autoriza sin persistir ni presentar.
Permite ampliar reglas sin modificar
la coordinacion del caso de uso.
end note
@enduml
