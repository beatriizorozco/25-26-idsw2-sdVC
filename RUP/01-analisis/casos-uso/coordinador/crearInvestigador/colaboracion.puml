@startuml crearInvestigador-analisis
skinparam linetype polyline

actor Coordinador
rectangle #CDEBA5 ":INVESTIGADORES_ABIERTOS" as InvestigadoresAbiertos
package crearInvestigador as "crearInvestigador()" {
    rectangle #629EF9 CrearInvestigadorView
    rectangle #b5bd68 CrearInvestigadorController
    rectangle #F2AC4E InvestigadorRepository
    rectangle #F2AC4E Investigador
}
rectangle #CDEBA5 ":INVESTIGADOR_ABIERTO" as InvestigadorAbierto
rectangle #CDEBA5 ":INVESTIGADORES_ABIERTOS" as CreacionCancelada

Coordinador -- InvestigadoresAbiertos
InvestigadoresAbiertos -r-> CrearInvestigadorView: crearInvestigador()
CrearInvestigadorView -d-> CrearInvestigadorController: registrarInvestigador(datosMinimos) : Investigador
CrearInvestigadorController --> InvestigadorRepository: existeUsuarioOCorreo(datosMinimos) : boolean
CrearInvestigadorController --> Investigador: crear(datosMinimos) : Investigador
CrearInvestigadorController --> InvestigadorRepository: guardar(Investigador) : Investigador
InvestigadorRepository -- Investigador
CrearInvestigadorView ..> InvestigadorAbierto: abrirInvestigador(idInvestigador)
CrearInvestigadorView ..> CreacionCancelada: cancelarCreacion()
@enduml
