@startuml agregarInvestigador-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":PROYECTO_ABIERTO" as EstadoEntrada
package agregarInvestigador as "agregarInvestigador()" {
    rectangle #629EF9 AgregarInvestigadorView
    rectangle #b5bd68 ProyectoController
    rectangle #b5bd68 ProyectoService
    rectangle #b5bd68 SesionService
    rectangle #F2AC4E ProyectoRepository
    rectangle #F2AC4E InvestigadorRepository
    rectangle #F2AC4E CargaTrabajoRepository
    rectangle #F2AC4E Proyecto
    rectangle #F2AC4E Investigador
    rectangle #F2AC4E CargaTrabajo
}

rectangle #CDEBA5 ":PROYECTO_ABIERTO" as EstadoSalida
rectangle #CDEBA5 ":Collaboration EditarProyecto" as EditarProyecto
rectangle #CDEBA5 ":Collaboration EliminarProyecto" as EliminarProyecto
rectangle #CDEBA5 ":Collaboration AgregarInvestigador" as AgregarInvestigador
rectangle #CDEBA5 ":Collaboration EliminarInvestigador" as EliminarInvestigador
rectangle #CDEBA5 ":Collaboration AbrirEntregables" as AbrirEntregables
rectangle #CDEBA5 ":Collaboration AbrirInvestigadores" as AbrirInvestigadores
rectangle #CDEBA5 ":Collaboration AbrirProyectos" as AbrirProyectos

EstadoEntrada -r-> AgregarInvestigadorView: agregarInvestigador(proyectoId)

AgregarInvestigadorView -d-> ProyectoController: prepararCandidatos(proyectoId)
ProyectoController --> ProyectoService: listarCandidatos(id)
ProyectoController --> ProyectoService: agregarInvestigador(id, investigadorId)
ProyectoController --> SesionService: obtenerSesionActual(authentication)
ProyectoService --> ProyectoRepository: obtenerPorId(proyectoId)
ProyectoService --> InvestigadorRepository: obtenerNoAsociados(proyectoId)
ProyectoService --> CargaTrabajoRepository: obtenerCargas(candidatos)
ProyectoService --> ProyectoService: evaluarCompatibilidadYDisponibilidad()
ProyectoService --> ProyectoService: recomendarMenorCargaCompatible()
AgregarInvestigadorView --> ProyectoController: asociarInvestigador(proyectoId, investigadorId)
ProyectoService --> ProyectoRepository: asociarInvestigador(proyectoId, investigadorId)
ProyectoRepository -- Proyecto
InvestigadorRepository -- Investigador
CargaTrabajoRepository -- CargaTrabajo
AgregarInvestigadorView ..> EstadoSalida: investigadorAsociado()
AgregarInvestigadorView ..> EstadoSalida: cancelarAsignacion()
AgregarInvestigadorView ..> EditarProyecto: editarProyecto()
AgregarInvestigadorView ..> EliminarProyecto: eliminarProyecto()
AgregarInvestigadorView ..> AgregarInvestigador: agregarInvestigador()
AgregarInvestigadorView ..> EliminarInvestigador: eliminarInvestigador()
AgregarInvestigadorView ..> AbrirEntregables: abrirEntregables()
AgregarInvestigadorView ..> AbrirInvestigadores: abrirInvestigadores()
AgregarInvestigadorView ..> AbrirProyectos: abrirProyectos()

@enduml
