@startuml abrirInvestigadores-analisis
skinparam linetype polyline

actor Coordinador
rectangle #CDEBA5 ":PANEL_PRINCIPAL_ABIERTO" as Panel
rectangle #CDEBA5 ":PROYECTO_ABIERTO" as ProyectoAbierto
package abrirInvestigadores as "abrirInvestigadores(idProyecto opcional)" {
    rectangle #629EF9 ListarInvestigadoresView
    rectangle #b5bd68 InvestigadoresController
    rectangle #F2AC4E InvestigadorRepository
    rectangle #F2AC4E ProyectoRepository
    rectangle #F2AC4E Investigador
}
rectangle #CDEBA5 ":INVESTIGADORES_ABIERTOS" as InvestigadoresAbiertos
rectangle #CDEBA5 ":Collaboration AbrirInvestigador" as AbrirInvestigador
rectangle #CDEBA5 ":Collaboration CrearInvestigador" as CrearInvestigador
rectangle #CDEBA5 ":Collaboration AbrirPanelPrincipal" as AbrirPanel

Coordinador -- Panel
Coordinador -- ProyectoAbierto
Panel -r-> ListarInvestigadoresView: abrirInvestigadores()
ProyectoAbierto -r-> ListarInvestigadoresView: abrirInvestigadores(idProyecto)
ListarInvestigadoresView -d-> InvestigadoresController: listarInvestigadores(idProyecto) : List<Investigador>
InvestigadoresController --> InvestigadorRepository: obtenerActivos() : List<Investigador>
InvestigadoresController --> ProyectoRepository: obtenerParticipantes(idProyecto) : List<Investigador>
ListarInvestigadoresView --> InvestigadoresController: filtrarInvestigadores(idProyecto, criterio) : List<Investigador>
InvestigadoresController --> InvestigadorRepository: buscarActivos(criterio) : List<Investigador>
InvestigadorRepository -- Investigador
ProyectoRepository -- Investigador
ListarInvestigadoresView ..> InvestigadoresAbiertos: investigadoresPresentados()
ListarInvestigadoresView ..> AbrirInvestigador: abrirInvestigador(idInvestigador)
ListarInvestigadoresView ..> CrearInvestigador: crearInvestigador()
ListarInvestigadoresView ..> AbrirPanel: abrirPanelPrincipal()
@enduml
