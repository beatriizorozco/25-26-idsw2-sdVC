@startuml abrirConvocatoria-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":CONVOCATORIAS_ABIERTAS" as EstadoEntrada
package abrirConvocatoria as "abrirConvocatoria()" {
    rectangle #629EF9 DetalleConvocatoriaView
    rectangle #b5bd68 ConvocatoriaController
    rectangle #F2AC4E ConvocatoriaRepository
    rectangle #F2AC4E Convocatoria
}

rectangle #CDEBA5 ":CONVOCATORIA_ABIERTA" as EstadoSalida
rectangle #CDEBA5 ":Collaboration AbrirConvocatorias" as AbrirConvocatorias

EstadoEntrada -r-> DetalleConvocatoriaView: abrirConvocatoria()

DetalleConvocatoriaView -d-> ConvocatoriaController: obtenerConvocatoria(id)
DetalleConvocatoriaView --> ConvocatoriaController: prepararAccionesDisponibles(coordinador)
ConvocatoriaController --> ConvocatoriaRepository: obtenerPorId(id)
ConvocatoriaController --> ConvocatoriaRepository: verificarPermisos(actor)
ConvocatoriaRepository -- Convocatoria
DetalleConvocatoriaView ..> EstadoSalida: continuarNavegacion()
DetalleConvocatoriaView ..> AbrirConvocatorias: abrirConvocatorias()

@enduml
