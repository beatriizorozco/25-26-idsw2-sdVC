@startuml abrirConvocatoria-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":CONVOCATORIAS_ABIERTAS" as Entrada
package abrirConvocatoria as "abrirConvocatoria()" {
    rectangle #629EF9 DetalleConvocatoriaView
    rectangle #b5bd68 ConvocatoriaController
    rectangle #b5bd68 ConsultaConvocatoriaService
    rectangle #b5bd68 SesionService
    rectangle #b5bd68 PoliticaConvocatoria
    rectangle #F2AC4E ConvocatoriaRepository
    rectangle #F2AC4E Convocatoria
}
rectangle #CDEBA5 ":CONVOCATORIA_ABIERTA" as Salida
rectangle #CDEBA5 ":Collaboration AbrirConvocatorias" as AbrirConvocatorias
rectangle #CDEBA5 ":Collaboration ImportarConvocatoria" as ImportarConvocatoria

Entrada -r-> DetalleConvocatoriaView: abrirConvocatoria(id)
DetalleConvocatoriaView -d-> ConvocatoriaController: obtenerConvocatoria(id, actor)
ConvocatoriaController --> SesionService: obtenerSesionActual(authentication)
ConvocatoriaController --> ConsultaConvocatoriaService: obtener(id, actor)
ConsultaConvocatoriaService --> PoliticaConvocatoria: permitirConsulta(actor)
ConsultaConvocatoriaService --> ConvocatoriaRepository: obtenerPorId(id)
ConvocatoriaRepository -- Convocatoria
DetalleConvocatoriaView ..> Salida: presentarDetalle()
DetalleConvocatoriaView ..> AbrirConvocatorias: abrirConvocatorias()
DetalleConvocatoriaView ..> ImportarConvocatoria: importarConvocatoria()
@enduml
