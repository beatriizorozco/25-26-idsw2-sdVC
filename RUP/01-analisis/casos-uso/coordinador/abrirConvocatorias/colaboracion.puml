@startuml abrirConvocatorias-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":PANEL_PRINCIPAL_ABIERTO" as Panel
rectangle #CDEBA5 ":CONVOCATORIA_ABIERTA" as Detalle
package abrirConvocatorias as "abrirConvocatorias()" {
    rectangle #629EF9 ListarConvocatoriasView
    rectangle #b5bd68 ConvocatoriaController
    rectangle #b5bd68 PoliticaConvocatoria
    rectangle #F2AC4E ConvocatoriaRepository
    rectangle #F2AC4E Convocatoria
}
rectangle #CDEBA5 ":CONVOCATORIAS_ABIERTAS" as Salida
rectangle #CDEBA5 ":Collaboration AbrirConvocatoria" as AbrirConvocatoria
rectangle #CDEBA5 ":Collaboration AbrirPanelPrincipal" as AbrirPanel

Panel -r-> ListarConvocatoriasView: abrirConvocatorias()
Detalle -r-> ListarConvocatoriasView: abrirConvocatorias()
ListarConvocatoriasView -d-> ConvocatoriaController: listarConvocatorias(filtro, actor)
ConvocatoriaController --> PoliticaConvocatoria: permitirConsulta(actor)
ConvocatoriaController --> ConvocatoriaRepository: buscar(filtro)
ConvocatoriaRepository -- Convocatoria
ListarConvocatoriasView ..> Salida: presentarListado()
ListarConvocatoriasView ..> AbrirConvocatoria: abrirConvocatoria(id)
ListarConvocatoriasView ..> AbrirPanel: abrirPanelPrincipal()

note right of ListarConvocatoriasView
El origen de navegacion no cambia
el alcance global del listado.
end note
@enduml
