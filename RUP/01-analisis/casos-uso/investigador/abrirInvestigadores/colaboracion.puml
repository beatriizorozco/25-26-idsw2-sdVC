@startuml abrirInvestigadores-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":PANEL_PRINCIPAL_ABIERTO" as EstadoEntrada1
rectangle #CDEBA5 ":PROYECTO_ABIERTO" as EstadoEntrada2
package abrirInvestigadores as "abrirInvestigadores()" {
    rectangle #629EF9 ListarInvestigadoresView
    rectangle #b5bd68 InvestigadorController
    rectangle #F2AC4E InvestigadorRepository
    rectangle #F2AC4E Investigador
}

rectangle #CDEBA5 ":INVESTIGADORES_ABIERTOS" as EstadoSalida
rectangle #CDEBA5 ":Collaboration AbrirInvestigador" as AbrirInvestigador
rectangle #CDEBA5 ":Collaboration AbrirPanelPrincipal" as AbrirPanelPrincipal

EstadoEntrada1 -r-> ListarInvestigadoresView: abrirInvestigadores()
EstadoEntrada2 -r-> ListarInvestigadoresView: abrirInvestigadores(idProyecto)

ListarInvestigadoresView -d-> InvestigadorController: listarInvestigadores(contexto)
ListarInvestigadoresView --> InvestigadorController: filtrarInvestigadores(criterio)
InvestigadorController --> InvestigadorRepository: obtenerTodos()
InvestigadorController --> InvestigadorRepository: obtenerPorContexto(contexto)
InvestigadorController --> InvestigadorRepository: buscarPorCriterio(criterio)
InvestigadorRepository -- Investigador
note right of InvestigadorController
Contexto opcional:
- sin identificador: listado propio
- con identificador: listado propio acotado
end note
ListarInvestigadoresView ..> EstadoSalida: continuarNavegacion()
ListarInvestigadoresView ..> AbrirInvestigador: abrirInvestigador()
ListarInvestigadoresView ..> AbrirPanelPrincipal: abrirPanelPrincipal()

@enduml
