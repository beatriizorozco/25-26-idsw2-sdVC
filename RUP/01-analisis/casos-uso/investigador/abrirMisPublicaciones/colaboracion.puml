@startuml abrirMisPublicaciones-investigador-analisis
skinparam linetype polyline

rectangle #CDEBA5 ":PANEL_PRINCIPAL_ABIERTO" as EstadoEntrada
package abrirMisPublicaciones as "abrirMisPublicaciones()" {
    rectangle #629EF9 "abrirMisPublicacionesView" as View
    rectangle #b5bd68 PublicacionController
    rectangle #b5bd68 PoliticaPublicacion
    rectangle #F2AC4E PublicacionRepository
    rectangle #F2AC4E Publicacion

}
rectangle #CDEBA5 ":MIS_PUBLICACIONES_ABIERTAS" as EstadoSalida

EstadoEntrada -r-> View: abrirMisPublicaciones()
View -d-> PublicacionController: abrirMisPublicaciones(solicitud, actor)

PublicacionController --> PoliticaPublicacion: alcancePropio(actor)
PublicacionController --> PublicacionRepository: buscarActivasPorAutor(actor, filtro)
PublicacionRepository -- Publicacion

View ..> EstadoSalida: continuarNavegacion()

note right of PoliticaPublicacion
Responsabilidad unica:
autoriza sin persistir ni presentar.
Permite ampliar reglas sin modificar
la coordinacion del caso de uso.
end note
@enduml
