@startuml abrirInvestigador
skinparam linetype polyline

state "OPCIONES_PERFIL_ABIERTO" as Perfil
state "INVESTIGADORES_ABIERTOS" as Investigadores

Perfil -[#green]-> abrirInvestigador: abrirInvestigador(idCoordinador)
Investigadores -[#green]-> abrirInvestigador: abrirInvestigador(idInvestigador)

state abrirInvestigador as "abrirInvestigador(idInvestigador)" {
    state " " as ConsultandoInvestigador
    state " " as PresentandoInvestigador

    [*] -[#green]-> ConsultandoInvestigador
    note on link
    <b>Coordinador</b> solicita abrir investigador
    end note

    ConsultandoInvestigador -[#green]-> PresentandoInvestigador
    note on link
    <b>Sistema</b> presenta el perfil consultable
    • Nombre, correo, sede, unidad, línea y biografía
    • Condición de investigador-docente según sede
    • Proyectos asociados
    • Permite solicitar abrir investigadores
    • Permite solicitar abrir proyectos
    • Permite solicitar abrir opciones de perfil cuando consulta su propio perfil
    end note

    PresentandoInvestigador -[#green]-> [*]
    note on link
    <b>Coordinador</b> solicita una opción
    end note
}

abrirInvestigador -[#green]-> INVESTIGADOR_ABIERTO: Investigador presentado
abrirInvestigador -[#green]-> OPCIONES_PERFIL_ABIERTO: abrirOpcionesPerfil()
abrirInvestigador -[#green]-> INVESTIGADORES_ABIERTOS: abrirInvestigadores()
abrirInvestigador -[#green]-> PROYECTOS_ABIERTOS: abrirProyectos()
@enduml
