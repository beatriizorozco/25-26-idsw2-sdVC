@startuml abrirProyecto
skinparam linetype polyline

state proyectos as "PROYECTOS_ABIERTOS"
state entregables as "ENTREGABLES_ABIERTOS"
proyectos -[#green]-> abrirProyecto
entregables -[#green]-> abrirProyecto

state abrirProyecto as "abrirProyecto(proyectoId)" {
    state " " as RecuperandoProyecto
    state " " as PresentandoProyecto

    [*] -[#green]-> RecuperandoProyecto
    note on link
    <b>Coordinador</b> solicita abrir el proyecto seleccionado
    end note

    RecuperandoProyecto -[#green]-> PresentandoProyecto
    note on link
    <b>Sistema</b> recupera el proyecto y presenta:
    • Código, título, estado, convocatoria y coordinador
    • Fechas y descripción
    • Equipo investigador y carga disponible
    • Entregables asociados

    Permite editar, eliminar, gestionar el equipo,
    abrir entregables o volver a proyectos
    end note

    PresentandoProyecto -[#green]-> [*]
    note on link
    <b>Coordinador</b> consulta el detalle o solicita una acción
    end note
}

abrirProyecto -[#green]-> PROYECTO_ABIERTO
abrirProyecto -[#green]-> PROYECTO_ABIERTO: editarProyecto()
abrirProyecto -[#green]-> PROYECTOS_ABIERTOS: eliminarProyecto()
abrirProyecto -[#green]-> PROYECTO_ABIERTO: agregarInvestigador()
abrirProyecto -[#green]-> PROYECTO_ABIERTO: eliminarInvestigador()
abrirProyecto -[#green]-> ENTREGABLES_ABIERTOS: abrirEntregables()
abrirProyecto -[#green]-> INVESTIGADORES_ABIERTOS: abrirInvestigadores()
abrirProyecto -[#green]-> PROYECTOS_ABIERTOS: abrirProyectos()

@enduml
