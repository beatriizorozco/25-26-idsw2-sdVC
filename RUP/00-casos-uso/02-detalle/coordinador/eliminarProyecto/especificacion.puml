@startuml eliminarProyecto
skinparam linetype polyline

state proyecto as "PROYECTO_ABIERTO"
proyecto -[#green]-> eliminarProyecto

state eliminarProyecto as "eliminarProyecto()" {
    state " " as ComprobandoDependencias
    state " " as ConfirmandoEliminacion

    [*] -[#green]-> ComprobandoDependencias
    note on link
    <b>Coordinador</b> solicita eliminar el proyecto abierto
    <b>Sistema</b> comprueba entregables, equipo,
    recompensas y demás información vinculada
    end note

    ComprobandoDependencias -[#red]-> [*]
    note on link
    <b>Sistema</b> impide la eliminación e informa
    las dependencias que deben resolverse o conservarse
    end note

    ComprobandoDependencias -[#green]-> ConfirmandoEliminacion
    note on link
    <b>Sistema</b> presenta el proyecto y solicita confirmación
    cuando puede eliminarse sin perder trazabilidad
    end note

    ConfirmandoEliminacion -[#green]-> [*]
    note on link
    <b>Coordinador</b> confirma
    <b>Sistema</b> elimina el proyecto
    end note

    ConfirmandoEliminacion -[#red]-> [*]
    note on link
    <b>Coordinador</b> cancela
    end note
}

eliminarProyecto -[#green]-> PROYECTOS_ABIERTOS: Proyecto eliminado
eliminarProyecto -[#red]-> PROYECTO_ABIERTO: Sin cambios

@enduml
