@startuml abrirInvestigadores
skinparam linetype polyline

state "PANEL_PRINCIPAL_ABIERTO" as Panel
state "PROYECTO_ABIERTO" as Proyecto

Panel -[#green]-> abrirInvestigadores: abrirInvestigadores()
Proyecto -[#green]-> abrirInvestigadores: abrirInvestigadores(idProyecto)

state abrirInvestigadores as "abrirInvestigadores(idProyecto opcional)" {
    state " " as MostrandoInvestigadores
    state " " as FiltrandoInvestigadores

    [*] -[#green]-> MostrandoInvestigadores
    note on link
    <b>Investigador</b> solicita abrir investigadores
    end note

    MostrandoInvestigadores -[#green]-> FiltrandoInvestigadores
    note on link
    <b>Sistema</b> presenta investigadores activos
    • Sin proyecto: presenta el directorio global
    • Con proyecto: presenta sus participantes
    • Nombre, sede, perfil y área
    • Permite solicitar filtrar lista
    • Permite solicitar abrir investigador
    • Permite solicitar abrir panel principal
    end note

    FiltrandoInvestigadores -[#green]-> FiltrandoInvestigadores
    note on link
    <b>Investigador</b> solicita filtrar lista
    <b>Sistema</b> presenta investigadores coincidentes dentro del alcance
    end note

    FiltrandoInvestigadores -[#green]-> [*]
    note on link
    <b>Investigador</b> solicita una opción
    end note
}

abrirInvestigadores -[#green]-> INVESTIGADORES_ABIERTOS: Investigadores presentados
abrirInvestigadores -[#green]-> INVESTIGADOR_ABIERTO: abrirInvestigador(idInvestigador)
abrirInvestigadores -[#green]-> PANEL_PRINCIPAL_ABIERTO: abrirPanelPrincipal()
@enduml
