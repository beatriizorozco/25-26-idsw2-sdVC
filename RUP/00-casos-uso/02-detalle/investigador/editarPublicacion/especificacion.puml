@startuml editarPublicacion
skinparam linetype polyline

state in1 as "MI_PUBLICACION_ABIERTA"
in1 -[#green]-> editarPublicacion : editarPublicacion()

state editarPublicacion as "editarPublicacion()" {
    state " " as VerificandoAutoria
    state " " as EditandoDatos
    state " " as ValidandoDatos

    [*] -[#green]-> VerificandoAutoria
    note on link
    <b>Investigador</b> solicita editar una publicacion propia
    end note

    VerificandoAutoria -[#green]-> EditandoDatos
    note on link
    <b>Sistema</b> verifica que el Investigador es su autor
    <b>Sistema</b> presenta titulo, contenido, estado,
    visibilidad y adjuntos editables
    end note

    EditandoDatos -[#green]-> ValidandoDatos
    note on link
    <b>Investigador</b> introduce cambios y solicita guardar
    end note

    ValidandoDatos -[#green]-> [*]
    note on link
    <b>Sistema</b> registra los cambios, conserva la trazabilidad
    y presenta la publicacion actualizada
    end note

    ValidandoDatos -[#red]-> EditandoDatos
    note on link
    <b>Sistema</b> presenta los errores de validacion
    end note

    EditandoDatos -[#red]-> [*]
    note on link
    <b>Investigador</b> solicita cancelar
    <b>Sistema</b> mantiene la publicacion sin cambios
    end note
}

editarPublicacion -[#green]-> MI_PUBLICACION_ABIERTA : Publicacion actualizada o sin cambios
@enduml
