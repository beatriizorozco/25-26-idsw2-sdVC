@startuml abrirInvestigador-coordinador-diseno
title Diagrama de secuencia - Abrir investigador como Coordinador

actor Coordinador
participant "InvestigadorDetallePage\n(React)" as Frontend
participant "InvestigadorController\n(Spring Boot)" as Api
participant "SesionService" as Sesion
participant "InvestigadorService" as Service
participant "UsuarioRepository" as UsuarioRepo
participant "ProyectoRepository" as ProyectoRepo
database "Base de Datos" as DB

Coordinador -> Frontend: Selecciona investigador
activate Frontend
Frontend -> Api: GET /api/investigadores/{id}?proyectoId={id?}\nCookie de sesion
activate Api
Api -> Sesion: obtenerSesionActual(authentication)
activate Sesion
alt Sesion valida
    Sesion --> Api: SesionResponse(usuario, rol)
    deactivate Sesion
    Api -> Service: obtenerDetalle(sesion, id, proyectoId?)
    activate Service
    Service -> UsuarioRepo: findById(id)
    UsuarioRepo -> DB: SELECT * FROM usuarios WHERE id = ?
    DB --> UsuarioRepo: Resultado de persistencia
    UsuarioRepo --> Service: Usuario / vacio
    alt Investigador inexistente, inactivo o no autorizado
        Service --> Api: RecursoNoEncontradoException
        deactivate Service
        Api --> Frontend: 404 Not Found
        deactivate Api
        Frontend --> Coordinador: Presenta investigador no disponible
    else Investigador existente
        Service -> ProyectoRepo: obtenerPorInvestigador(id, proyectoId?)
        ProyectoRepo -> DB: SELECT p.* FROM proyectos p JOIN proyecto_investigadores pi ON pi.proyecto_id = p.id WHERE pi.usuario_id = ?
        DB --> ProyectoRepo: Resultado de persistencia
        ProyectoRepo --> Service: Lista<ProyectoResumen>
        Service --> Api: InvestigadorDetalleResponse
        deactivate Service
        Api --> Frontend: 200 OK\nDetalle del investigador
        deactivate Api
        Frontend --> Coordinador: Presenta INVESTIGADOR_ABIERTO
    end
else Sesion ausente o invalida
    Sesion --> Api: SesionNoValidaException
    deactivate Sesion
    Api --> Frontend: 401 Unauthorized
    deactivate Api
    Frontend --> Coordinador: Presenta error de acceso
end
deactivate Frontend
@enduml
