@startuml abrirInvestigador-coordinador-diseno
title Diagrama de secuencia - Abrir investigador como Coordinador

actor Coordinador
participant "InvestigadorDetallePage\n(React)" as Frontend
participant "InvestigadorController\n(Spring Boot)" as Api
participant "SesionService" as Sesion
participant "InvestigadorService" as Service
participant "InvestigadorRepository" as InvestigadorRepo
participant "ProyectoRepository" as ProyectoRepo

Coordinador -> Frontend: Selecciona investigador
activate Frontend
Frontend -> Api: GET /api/investigadores/{id}\nCookie de sesion
activate Api
Api -> Sesion: exigirCoordinador(authentication)
activate Sesion
alt Sesion de Coordinador activa
    Sesion --> Api: Coordinador autenticado
    deactivate Sesion
    Api -> Service: obtenerDetalle(id)
    activate Service
    Service -> InvestigadorRepo: obtenerActivoPorId(id)
    InvestigadorRepo --> Service: Investigador / vacio
    alt Investigador inexistente o inactivo
        Service --> Api: RecursoNoEncontradoException
        deactivate Service
        Api --> Frontend: 404 Not Found
        deactivate Api
        Frontend --> Coordinador: Presenta investigador no disponible
    else Investigador existente
        Service -> ProyectoRepo: obtenerPorInvestigador(id)
        ProyectoRepo --> Service: Lista<Proyecto>
        Service --> Api: InvestigadorDetalleResponse
        deactivate Service
        Api --> Frontend: 200 OK\nDetalle del investigador
        deactivate Api
        Frontend --> Coordinador: Presenta INVESTIGADOR_ABIERTO
    end
else Sesion ausente o rol invalido
    Sesion --> Api: SesionNoValidaException / AccesoDenegadoException
    deactivate Sesion
    Api --> Frontend: 401 Unauthorized / 403 Forbidden
    deactivate Api
    Frontend --> Coordinador: Presenta error de acceso
end
deactivate Frontend
@enduml
