@startuml abrirRecompensas-coordinador-diseno
title Diagrama de secuencia - Abrir recompensas como Coordinador

actor Coordinador
participant "RecompensasPage\n(React)" as Frontend
participant "RecompensaController\n(Spring Boot)" as Api
participant "SesionService" as Sesion
participant "RecompensaService" as Service
participant "RecompensaRepository" as Repo
participant "ProyectoRepository" as ProyectoRepo
participant "InvestigadorRepository" as InvestigadorRepo
database "Base de Datos" as DB

Coordinador -> Frontend: Solicita abrir recompensas
activate Frontend
Frontend -> Api: GET /api/recompensas?criterio={criterio}\nCookie de sesion
activate Api
Api -> Sesion: exigirCoordinador(authentication)
activate Sesion
alt Sesion de Coordinador activa
    Sesion --> Api: Coordinador autenticado
    deactivate Sesion
    Api -> Service: listarGlobales(criterio)
    activate Service
    Service -> Repo: buscarDeProyectosCompletados(criterio)
    Repo -> DB: SELECT r.* FROM recompensas r JOIN proyectos p ON p.id = r.proyecto_id WHERE p.estado = 'COMPLETADO' AND r.anulada = false
    DB --> Repo: Resultado de persistencia
    activate Repo
    Repo --> Service: Lista<Recompensa>
    deactivate Repo
    Service -> ProyectoRepo: obtenerResumenes(proyectoIds)
    ProyectoRepo -> DB: SELECT * FROM proyectos WHERE id IN (?)
    DB --> ProyectoRepo: Resultado de persistencia
    ProyectoRepo --> Service: Proyectos completados
    Service -> InvestigadorRepo: obtenerResumenes(beneficiarioIds)
    InvestigadorRepo -> DB: SELECT * FROM usuarios WHERE id IN (?)
    DB --> InvestigadorRepo: Resultado de persistencia
    InvestigadorRepo --> Service: Beneficiarios
    Service --> Api: Lista<RecompensaResumenResponse>
    deactivate Service
    Api --> Frontend: 200 OK\nLista de recompensas
    deactivate Api
    Frontend --> Coordinador: Presenta RECOMPENSAS_ABIERTAS
else Sesion ausente o rol invalido
    Sesion --> Api: SesionNoValidaException / AccesoDenegadoException
    deactivate Sesion
    Api --> Frontend: 401 Unauthorized / 403 Forbidden
    deactivate Api
    Frontend --> Coordinador: Presenta error de acceso
end
deactivate Frontend
@enduml
