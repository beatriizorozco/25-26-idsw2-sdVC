@startuml abrirMiPublicacion-coordinador-diseno
title Diagrama de secuencia - abrirMiPublicacion
actor Coordinador
participant "abrirMiPublicacionPage\n(React)" as Frontend
participant "PublicacionController\n(Spring Boot)" as Api
participant "SesionService" as Sesion
participant "PublicacionService" as Service
participant "PoliticaPublicacion" as Policy
participant "PublicacionRepository" as Repo
participant "RespuestaRepository" as RespRepo
participant "ArchivoPublicacionRepository" as ArchivoRepo
database "Base de Datos" as DB

Coordinador -> Frontend: Solicita abrirMiPublicacion()
Frontend -> Api: GET /api/publicaciones/me/{id} + cookie
Api -> Sesion: exigirCoordinador(authentication)
Sesion --> Api: Actor autenticado
Api -> Service: obtenerPropia(id, actor)
Service -> Repo: obtenerActivaPorId(id)
Repo -> DB: SELECT * FROM publicaciones\nWHERE id = ? AND retirada = false
DB --> Repo: Publicacion / vacio
Service -> Policy: exigirAutoria(actor, publicacion)
Service -> RespRepo: buscarPorPublicacion(id)
RespRepo -> DB: SELECT * FROM respuestas_publicacion\nWHERE publicacion_id = ? ORDER BY fecha
DB --> RespRepo: Respuestas
Service -> ArchivoRepo: buscarPorPublicacion(id)
ArchivoRepo -> DB: SELECT * FROM archivos_publicacion\nWHERE publicacion_id = ? AND retirado = false
DB --> ArchivoRepo: Adjuntos
Service --> Api: Resultado del caso de uso
Api --> Frontend: 200 OK (PublicacionResponse)
Frontend --> Coordinador: Presenta MI_PUBLICACION_ABIERTA
@enduml
