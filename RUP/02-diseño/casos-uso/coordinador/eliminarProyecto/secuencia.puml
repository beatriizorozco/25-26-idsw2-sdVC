@startuml eliminarProyecto-coordinador-diseno
title Diagrama de secuencia - Eliminar proyecto

actor Coordinador
participant "ProyectoDetallePage\n(React)" as Frontend
participant "ProyectoController\n(Spring Boot)" as Api
participant "SesionService" as Sesion
participant "ProyectoService" as Service
participant "ProyectoRepository" as Repo

Coordinador -> Frontend: Solicita eliminar proyecto
activate Frontend
Frontend -> Api: GET /api/proyectos/{id}/opciones-archivado\nCookie de sesion
activate Api
Api -> Sesion: exigirCoordinador(authentication)
Sesion --> Api: Coordinador autenticado
Api -> Service: prepararArchivado(id)
activate Service
Service -> Repo: obtenerPorId(id)
Repo --> Service: Proyecto / vacio
Service -> Repo: obtenerResumenHistorico(id)
Repo --> Service: Estado, equipo y elementos vinculados
Service --> Api: OpcionesArchivadoProyectoResponse
deactivate Service
Api --> Frontend: 200 OK\nConsecuencias del archivado
deactivate Api
Frontend --> Coordinador: Presenta confirmacion de archivado
alt Coordinador cancela
    Coordinador -> Frontend: Cancela archivado
    Frontend --> Coordinador: Conserva PROYECTO_ABIERTO
else Coordinador confirma
    Coordinador -> Frontend: Confirma archivado
    Frontend -> Api: DELETE /api/proyectos/{id}\nCookie de sesion
    activate Api
    Api -> Sesion: exigirCoordinador(authentication)
    Sesion --> Api: Coordinador autenticado
    Api -> Service: archivar(id, coordinador)
    activate Service
    Service -> Repo: obtenerActivoPorId(id)
    Repo --> Service: Proyecto / vacio
    alt Proyecto inexistente o ya archivado
        Service --> Api: RecursoNoEncontradoException / ConflictoException
        deactivate Service
        Api --> Frontend: 404 Not Found / 409 Conflict
        deactivate Api
        Frontend --> Coordinador: Presenta error y conserva PROYECTO_ABIERTO
    else Proyecto activo
        Service -> Repo: archivar(id, fecha, coordinador)
        Repo --> Service: Proyecto archivado
        note right of Service
        Se conservan estado, equipo,
        entregables y recompensas.
        end note
        Service --> Api: archivado completado
        deactivate Service
        Api --> Frontend: 204 No Content
        deactivate Api
        Frontend --> Coordinador: Presenta PROYECTOS_ABIERTOS
    end
end
deactivate Frontend
@enduml
