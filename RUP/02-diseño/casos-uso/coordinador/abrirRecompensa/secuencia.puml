@startuml abrirRecompensa-coordinador-diseno
title Diagrama de secuencia - Abrir recompensa como Coordinador

actor Coordinador
participant "RecompensaDetallePage\n(React)" as Frontend
participant "RecompensaController\n(Spring Boot)" as Api
participant "SesionService" as Sesion
participant "RecompensaService" as Service
participant "RecompensaRepository" as Repo
participant "ProyectoRepository" as ProyectoRepo
participant "UsuarioRepository" as InvestigadorRepo
database "Base de Datos" as DB

Coordinador -> Frontend: Selecciona una recompensa
activate Frontend
Frontend -> Api: GET /api/recompensas/{id}\nCookie de sesion
activate Api
Api -> Sesion: obtenerSesionActual(authentication)
activate Sesion
alt Sesion de Coordinador activa
    Sesion --> Api: Coordinador autenticado
    deactivate Sesion
    Api -> Service: obtenerGlobal(id)
    activate Service
    Service -> Repo: findById(id)
    Repo -> DB: SELECT * FROM recompensas WHERE id = ?
    DB --> Repo: Resultado de persistencia
    Repo --> Service: Recompensa
    alt Recompensa existente
        Service -> ProyectoRepo: findById(recompensa.proyectoId)
        ProyectoRepo -> DB: SELECT * FROM proyectos WHERE id = ? AND estado = 'COMPLETADO'
        DB --> ProyectoRepo: Resultado de persistencia
        ProyectoRepo --> Service: Proyecto completado
        Service -> InvestigadorRepo: findById(recompensa.investigadorId)
        InvestigadorRepo -> DB: SELECT * FROM usuarios WHERE id = ? AND activo = true
        DB --> InvestigadorRepo: Resultado de persistencia
        InvestigadorRepo --> Service: Beneficiario con sede y condicion
        Service -> Service: validarDatos()
        Service --> Api: RecompensaDetalleResponse
        deactivate Service
        Api --> Frontend: 200 OK\nDetalle y acciones de gestion
        deactivate Api
        Frontend --> Coordinador: Presenta RECOMPENSA_ABIERTA
    else Recompensa inexistente
        Service --> Api: RecursoNoEncontradoException
        deactivate Service
        Api --> Frontend: 404 Not Found
        deactivate Api
        Frontend --> Coordinador: Presenta recompensa no encontrada
    end
else Sesion ausente o rol invalido
    Sesion --> Api: SesionNoValidaException / AccesoDenegadoException
    deactivate Sesion
    Api --> Frontend: 401 Unauthorized / 403 Forbidden
    deactivate Api
    Frontend --> Coordinador: Presenta error de acceso
end
deactivate Frontend
@enduml
