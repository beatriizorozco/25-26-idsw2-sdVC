@startuml abrirInvestigador-investigador-diseno
title Diagrama de secuencia - Abrir investigador como Investigador

actor Investigador
participant "InvestigadorDetallePage\n(React)" as Frontend
participant "InvestigadorController\n(Spring Boot)" as Api
participant "SesionService" as Sesion
participant "InvestigadorService" as Service
participant "InvestigadorRepository" as InvestigadorRepo
participant "ProyectoRepository" as ProyectoRepo

Investigador -> Frontend: Selecciona investigador visible
activate Frontend
Frontend -> Api: GET /api/investigadores/me/{id}?proyectoId={proyectoId}\nCookie de sesion
activate Api
Api -> Sesion: exigirInvestigador(authentication)
activate Sesion
alt Sesion de Investigador activa
    Sesion --> Api: Investigador autenticado
    deactivate Sesion
    Api -> Service: obtenerDetalleVisible(investigadorId, id, proyectoId)
    activate Service
    Service -> InvestigadorRepo: obtenerActivoPorId(id)
    InvestigadorRepo --> Service: Investigador / vacio
    Service -> ProyectoRepo: obtenerVisiblesCompartidos(id, investigadorId, proyectoId)
    ProyectoRepo --> Service: Lista<Proyecto>
    alt Investigador inexistente o no visible
        Service --> Api: RecursoNoEncontradoException
        deactivate Service
        Api --> Frontend: 404 Not Found
        deactivate Api
        Frontend --> Investigador: Presenta investigador no disponible
    else Investigador visible
        Service --> Api: InvestigadorDetalleResponse
        deactivate Service
        Api --> Frontend: 200 OK\nDetalle visible del investigador
        deactivate Api
        Frontend --> Investigador: Presenta INVESTIGADOR_ABIERTO
    end
else Sesion ausente o rol invalido
    Sesion --> Api: SesionNoValidaException / AccesoDenegadoException
    deactivate Sesion
    Api --> Frontend: 401 Unauthorized / 403 Forbidden
    deactivate Api
    Frontend --> Investigador: Presenta error de acceso
end
deactivate Frontend
@enduml
