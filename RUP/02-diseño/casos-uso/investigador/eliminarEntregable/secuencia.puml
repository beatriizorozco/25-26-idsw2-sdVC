@startuml eliminarEntregable-investigador-diseno
title Diagrama de secuencia - Retirar entregable propio
actor Investigador
participant "EntregableDetallePage\n(React)" as Frontend
participant "EntregableController\n(Spring Boot)" as Api
participant "SesionService" as Sesion
participant "EntregableService" as Service
participant "EntregableRepository" as Repo
database "Base de Datos" as DB

Investigador -> Frontend: Solicita retirar entregable propio
Frontend --> Investigador: Presenta confirmacion y solicita motivo
alt Investigador cancela
  Frontend --> Investigador: Conserva ENTREGABLE_ABIERTO
else Investigador confirma
  Investigador -> Frontend: Confirma retirada con motivo
  Frontend -> Api: PATCH /api/entregables/{id}/retirada\nmotivo + cookie
  Api -> Sesion: obtenerSesionActual(authentication)
  Sesion --> Api: Investigador autenticado
  Api -> Service: retirar(id, motivo, investigador)
  Service -> Repo: findByIdAndRetirado(id, investigador)
  Repo -> DB: SELECT * FROM entregables\nWHERE id = ? AND autor_id = ? AND retirado = false
  DB --> Repo: Entregable propio / vacio
  Repo --> Service: Entregable propio / vacio
  Service -> Repo: save(id, fecha, investigador, motivo)
  Repo -> DB: UPDATE entregables SET retirado = true,\nfecha_retirada = ?, retirado_por_id = ?, motivo_retirada = ?\nWHERE id = ? AND autor_id = ?
  DB --> Repo: Entregable retirado
  Repo --> Service: Entregable retirado
  note right of Repo
  Conserva autoria, proyecto,
  archivos y versiones.
  end note
  Service --> Api: EntregableRetiradoResponse
  Api --> Frontend: 200 OK
  Frontend --> Investigador: Presenta ENTREGABLES_ABIERTOS
end
@enduml
